filters:
  and:
    - file.inFolder("030-Модули")
    - file.ext == "md"
    - file.name != "030-Модули"
properties:
  status:
    displayName: Статус
  updated:
    displayName: Обновлено
views:
  - type: table
    name: Все Модули
    groupBy:
      property: status
      direction: ASC
    order:
      - file.name
      - status
      - updated
