# Database connection string
DATABASE_URL=postgresql://postgres:postgres@db:5432/merch_crm

# S3 Storage (Optional for avatars/files)
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_ENDPOINT=https://your-s3-endpoint.com
S3_BUCKET=merch-crm-uploads

# Node Environment
NODE_ENV=development

# Redis (Optional but recommended for sessions/rate-limiting)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=

# General Security Secret (for Better Auth, CSRF, JWT)
AUTH_SECRET=change-this-to-a-very-long-and-secure-random-string
BETTER_AUTH_URL=http://localhost:3000

# Email
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=noreply@yourdomain.com

# Presence API (Security)
# Must be at least 16 characters long
PRESENCE_SERVICE_API_KEY=at-least-16-chars-long-secure-key

# AUTH_SECRET_PREVIOUS (Optional, used during secret rotation)
AUTH_SECRET_PREVIOUS=
