{
  "mcpServers": {
    "context7": {
      "command": "/usr/local/bin/npx",
      "args": [
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "YOUR_API_KEY"
      ]
    },
    "shadcn": {
      "command": "/usr/local/bin/npx",
      "args": [
        "shadcn@latest",
        "mcp"
      ]
    }
    //other mcp servers
  }
}

// setup mcp server in ~/.gemini\antigravity\mcp_config.json

