{
  "name": "merch-crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "dev:debug": "NODE_OPTIONS='--max-old-space-size=4096 --inspect' next dev",
    "dev:analyze": "ANALYZE=true next dev",
    "dev:ssh": "./scripts/dev.sh",
    "stop:ssh": "./scripts/stop-dev.sh",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "npx tsx scripts/db-migrate.ts",
    "db:studio": "drizzle-kit studio",
    "audit": "npx tsx scripts/audit.ts",
    "audit:quick": "npx tsc --noEmit && npm run lint",
    "audit:fix": "npm run lint -- --fix",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:all": "npm run test && npm run test:integration && npm run test:e2e",
    "generate-favicon": "node scripts/generate-favicon.cjs",
    "secret:rotate": "npx tsx scripts/rotate-secret.ts",
    "secret:status": "npx tsx -e \"import { getRotationStatus } from './lib/secrets-rotation'; console.log(getRotationStatus())\"",
    "analyze:memory": "npx tsx scripts/analyze-memory.ts",
    "analyze:bundle": "npx @next/bundle-analyzer",
    "docs": "typedoc --options typedoc.json",
    "docs:watch": "typedoc --options typedoc.json --watch",
    "session:log": "npx tsx scripts/log-session.ts",
    "session:handoff": "npx tsx scripts/session-handoff.ts",
    "security:audit": "ship-safe audit .",
    "security:audit:deep": "ship-safe audit . --deep",
    "security:red-team": "ship-safe red-team .",
    "security:init": "ship-safe init",
    "security:vibe-check": "ship-safe vibe-check .",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
